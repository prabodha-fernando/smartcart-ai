{
  // Tailwind CSS v4 uses at-rules (@theme, @apply, @import "tailwindcss", …)
  // that VS Code's built-in CSS linter doesn't know, so it wrongly flags them
  // as "Unknown at rule". Turn off that one lint rule — the CSS is valid.
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore"
}
