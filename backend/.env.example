# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated allowed CORS origins (the Next.js frontend)
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────
# Local docker-compose Mongo (see docker-compose.yml), or a MongoDB Atlas URI.
MONGODB_URI=mongodb://localhost:27017/smartcart

# ── Auth / JWT ────────────────────────────────────────────
# Use long random strings in production, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET=replace-with-at-least-16-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-16-character-secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ── Upstream products ─────────────────────────────────────
DUMMYJSON_BASE_URL=https://dummyjson.com

# AI proxy (server-only; never expose these with a NEXT_PUBLIC_ prefix)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEY=
AI_RATE_LIMIT_PER_MINUTE=20
